# ── Copy this file to .env and fill in your values ──────────────────────────

# Application
APP_NAME="AI Traffic Violation Detection System"
ENVIRONMENT=development
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=2

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/traffic_violations

# Redis
REDIS_URL=redis://localhost:6379/0

# File paths
UPLOAD_DIR=data/uploads
EVIDENCE_DIR=data/evidence
REPORTS_DIR=data/reports
MODEL_DIR=data/models
MAX_UPLOAD_SIZE_MB=50

# YOLOv11 Model
YOLO_VEHICLE_MODEL=yolov11n.pt
YOLO_HELMET_MODEL=yolov11_helmet.pt
YOLO_PLATE_MODEL=yolov11_plate.pt
YOLO_CONFIDENCE_THRESHOLD=0.45
YOLO_IOU_THRESHOLD=0.45
YOLO_DEVICE=cpu        # Options: cpu | cuda | mps
YOLO_IMAGE_SIZE=640

# ByteTrack
TRACKER_MAX_AGE=30
TRACKER_MIN_HITS=3

# OCR
OCR_ENGINE=easyocr    # Options: easyocr | paddleocr
OCR_LANGUAGES=["en"]
OCR_CONFIDENCE_THRESHOLD=0.5

# Violation detection
ILLEGAL_PARKING_DURATION_SECONDS=300
TRIPLE_RIDING_MIN_COUNT=3

# Security (change in production!)
SECRET_KEY=REPLACE_WITH_RANDOM_64_CHAR_STRING
ENABLE_API_KEY_AUTH=false

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
